# --- Frontend (Vite — exposed to the browser, safe public keys only) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Server / Netlify functions only (NEVER prefixed with VITE_, never committed) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
ANTHROPIC_API_KEY=

# --- Toilet Roll Sprint (server-side only — Director gate + future Sage sync) ---
# Director login PIN, validated server-side (defaults to the brief's PIN if unset).
DIRECTOR_PIN=01237470990
# Secret used to sign director session tokens (defaults to the PIN if unset; set a
# long random value in production).
DIRECTOR_TOKEN_SECRET=
# Public base URL of the Sprint app, used to build the marketing_app_url deep link
# written to the marketing app's promotions row (e.g. https://wg-sprints.netlify.app).
SPRINT_BASE_URL=
# Marketing-app ROI integration. The Sprint hosts its toilet_roll schema in the
# WG Main database, so SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY above point at WG
# Main and the same service-role client reads vw_campaign_codes_master and writes
# public.promotions. Leave this OFF until the integration is verified — when not
# "true", ROI registration is a dry run that writes nothing.
MARKETING_ROI_ENABLED=false

# --- Publishing (Phase 3 — behind PublishingProvider interface) ---
PUBLISHING_PROVIDER=manual        # manual | ayrshare | postiz
PUBLISHING_API_KEY=

# --- Catalogue (Phase 6 — manual in-app for v1) ---
CATALOGUE_SOURCE=manual           # manual | static-html | shopify | woo

# --- eBay (Phase 7) ---
EBAY_ENV=sandbox
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_REDIRECT_URI=
EBAY_REFRESH_TOKEN=

# --- Photo bank: Google Drive (server-side, never prefixed with VITE_) ---
# Paste the FULL service-account key JSON on one line (keep \n inside private_key).
GOOGLE_SERVICE_ACCOUNT_JSON=
# Drive folder IDs — the long string in each folder's URL after /folders/
DRIVE_FOLDER_INSPIRATION_ID=
DRIVE_FOLDER_NEW_ID=
DRIVE_FOLDER_STOCK_ID=

# --- Local watched-folder service (Phase 2 — optional, later) ---
WATCH_FOLDER_PATH=
